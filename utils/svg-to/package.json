{
  "name": "svg-to",
  "version": "0.1.0",
  "license": "MIT",
  "private": "false",
  "author": "@pheralb_",
  "description": "A utility to convert SVG code to other frameworks",
  "files": [
    "dist/**"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@svgr/core": "8.1.0",
    "@svgr/plugin-jsx": "8.1.0",
    "svgo": "3.3.2",
    "vue-template-compiler": "2.7.16"
  },
  "devDependencies": {
    "@eslint/js": "9.11.1",
    "eslint": "9.11.1",
    "tsup": "8.3.0",
    "typescript-eslint": "8.7.0"
  }
}
